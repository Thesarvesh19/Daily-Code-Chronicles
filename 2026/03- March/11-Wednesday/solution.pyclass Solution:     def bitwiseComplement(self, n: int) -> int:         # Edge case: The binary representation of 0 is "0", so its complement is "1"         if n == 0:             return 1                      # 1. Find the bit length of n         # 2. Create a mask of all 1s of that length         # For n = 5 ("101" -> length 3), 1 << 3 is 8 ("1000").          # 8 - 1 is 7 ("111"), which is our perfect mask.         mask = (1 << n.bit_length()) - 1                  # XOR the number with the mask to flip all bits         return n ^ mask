class Solution:
    def bitwiseComplement(self, n: int) -> int:
        # Edge case: The binary representation of 0 is "0", so its complement is "1"
        if n == 0:
            return 1
            
        # 1. Find the bit length of n
        # 2. Create a mask of all 1s of that length
        # For n = 5 ("101" -> length 3), 1 << 3 is 8 ("1000"). 
        # 8 - 1 is 7 ("111"), which is our perfect mask.
        mask = (1 << n.bit_length()) - 1
        
        # XOR the number with the mask to flip all bits
        return n ^ mask
